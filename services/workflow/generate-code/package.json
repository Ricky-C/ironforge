{
  "name": "@ironforge/workflow-generate-code",
  "version": "0.0.0",
  "private": true,
  "description": "Workflow task Lambda — generate-code. Renders templates/static-site/starter-code/ files (build-time snapshot) and pushes the rendered tree as the initial commit on the user's repo via Octokit Git Data API.",
  "license": "UNLICENSED",
  "scripts": {
    "build": "node ./build.mjs",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ironforge/shared-types": "workspace:*",
    "@ironforge/shared-utils": "workspace:*",
    "@ironforge/template-renderer": "workspace:*"
  },
  "devDependencies": {
    "@aws-sdk/lib-dynamodb": "^3.1042.0",
    "@types/node": "^25.6.0",
    "aws-sdk-client-mock": "^4.1.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  }
}
