    "@octokit/plugin-retry": "^8.0.1",
    "@octokit/rest": "^22.0.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "aws-sdk-client-mock": "^4.1.0",
    "nock": "^14.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
