# Ironforge portal — build-time environment variables.
# Copy to apps/web/.env.local and populate. .env.local is gitignored
# at the repo root.
#
# All three are NEXT_PUBLIC_* — Next.js inlines them into the client
# JS bundle at `next build`. Bundles are env-specific; CI passes them
# via Docker --build-arg per .github/workflows/app-deploy.yml. The
# values themselves are non-sensitive (public Cognito client_id, public
# API URL, public OIDC authority); none of these are secrets.
#
# What does NOT belong here: the redirect URI and post-logout URI. Both
# are computed at runtime from window.location.origin, so the same
# bundle works at localhost:3000 and the prod domain.

# Cognito user pool issuer URL. OIDC discovery doc lives at
# ${authority}/.well-known/openid-configuration; oidc-client-ts pulls
# all endpoints (authorization, token, end_session, userinfo) from
# there, so we don't have to track them individually.
# Example: https://cognito-idp.us-east-1.amazonaws.com/us-east-1_xxxxxxxxx
NEXT_PUBLIC_COGNITO_AUTHORITY=

# Cognito app client ID — env-specific. Dev's client_id and prod's
# client_id are different, by design (per ADR-005's audience-claim
# isolation pattern).
NEXT_PUBLIC_COGNITO_CLIENT_ID=

# API Gateway base URL — env-specific (dev / prod APIs are separate).
# No trailing slash; api-client appends `/api/...` paths.
# Re-derive via `aws apigatewayv2 get-apis` if the API id rotates.
NEXT_PUBLIC_API_BASE_URL=
