# Ironforge dev environment variables.
# Copy to apps/web/.env.local and populate. .env.local is gitignored
# at the repo root.
#
# These are SERVER-SIDE ONLY (no NEXT_PUBLIC_ prefix). The Next.js
# dev proxy at /api/dev/proxy reads them server-side and forwards
# authenticated requests to the real API. Client bundle never sees
# the bearer token.
#
# When subphase 2.5 (auth) lands and the real Cognito flow ships,
# the dev proxy and these variables go away. The api-client switches
# to direct API calls with the access token from oidc-client-ts.

# Dev API Gateway URL (no trailing slash).
# Re-derive via `aws apigatewayv2 get-apis` if the API id rotates.
IRONFORGE_API_BASE_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com

# Bearer access token for the synthetic test user.
# Run `pnpm mint-test-token` from the repo root to mint a fresh
# token (30-minute validity per the Cognito app client config).
# Re-mint when 401s start coming back from the proxy.
IRONFORGE_DEV_BEARER_TOKEN=
